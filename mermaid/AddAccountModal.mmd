flowchart TD
    classDef init fill:#d4edda,stroke:#28a745,stroke-width:2px,color:#155724
    classDef cond fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#856404
    classDef action fill:#cce5ff,stroke:#007bff,stroke-width:2px,color:#004085
    classDef ui fill:#e2e3e5,stroke:#6c757d,stroke-width:2px,color:#383d41
    classDef error fill:#f8d7da,stroke:#dc3545,stroke-width:2px,color:#721c24

    Start(["Nhận Props: visible, onClose, onSuccess"]):::init --> RenderUI["Hiển thị Modal Thêm Tài Khoản"]:::ui
    
    RenderUI --> UserInput["Người dùng nhập: Tên, Số dư ban đầu, Loại tài khoản"]:::ui
    UserInput --> ClickSave["Nhấn 'Save'"]:::action
    
    ClickSave --> ValidateName{"Tên có trống không?"}:::cond
    ValidateName -- Có --> ShowErrorName["Hiển thị lỗi: 'Account name is required'"]:::error
    ValidateName -- Không --> ValidateBalance{"Số dư hợp lệ?"}:::cond
    
    ValidateBalance -- Không --> ShowErrorBalance["Hiển thị lỗi: 'Invalid balance amount'"]:::error
    ValidateBalance -- Có --> CreateAccount["Gọi AccountController.createAccount()"]:::action
    
    CreateAccount --> CheckResult{"Kết quả tạo thành công?"}:::cond
    CheckResult -- Có --> SuccessFlow["Reset Form -> Gọi onSuccess() -> Gọi onClose()"]:::init
    CheckResult -- Không --> ShowErrorCreate["Hiển thị lỗi từ Controller"]:::error
