flowchart TD
    classDef init fill:#d4edda,stroke:#28a745,stroke-width:2px,color:#155724
    classDef cond fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#856404
    classDef action fill:#cce5ff,stroke:#007bff,stroke-width:2px,color:#004085
    classDef ui fill:#e2e3e5,stroke:#6c757d,stroke-width:2px,color:#383d41
    classDef error fill:#f8d7da,stroke:#dc3545,stroke-width:2px,color:#721c24

    Start(["Nhận Props: visible, onClose, onSuccess"]):::init --> UseEffect["Chạy useEffect() để Load Data"]:::action
    UseEffect --> FetchDeps["Lấy danh sách Accounts và Categories từ DB"]:::action
    FetchDeps --> RenderUI["Hiển thị Modal Thêm Giao Dịch"]:::ui
    
    RenderUI --> UserInput["Người dùng chọn: Loại (Income/Expense), Số tiền, Ghi chú, Tài khoản, Danh mục"]:::ui
    UserInput --> ClickSave["Nhấn 'Save'"]:::action
    
    ClickSave --> ValidateAmount{"Số tiền hợp lệ?"}:::cond
    ValidateAmount -- Không --> ShowErrorAmount["Hiển thị lỗi: 'Please enter a valid amount'"]:::error
    ValidateAmount -- Có --> ValidateAccount{"Đã chọn Tài khoản?"}:::cond
    
    ValidateAccount -- Không --> ShowErrorAccount["Hiển thị lỗi: 'Please select an account'"]:::error
    ValidateAccount -- Có --> ValidateCategory{"Đã chọn Danh mục (nếu không phải Transfer)?"}:::cond
    
    ValidateCategory -- Không --> ShowErrorCategory["Hiển thị lỗi: 'Please select a category'"]:::error
    ValidateCategory -- Có --> CreateTx["Gọi TransactionController.createTransaction()"]:::action
    
    CreateTx --> CheckResult{"Kết quả lưu thành công?"}:::cond
    CheckResult -- Có --> SuccessFlow["Clear Form -> Gọi onSuccess() -> Gọi onClose()"]:::init
    CheckResult -- Không --> ShowErrorCreate["Hiển thị lỗi từ Controller"]:::error
