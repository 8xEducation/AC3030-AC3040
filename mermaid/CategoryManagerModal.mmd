flowchart TD
    classDef init fill:#d4edda,stroke:#28a745,stroke-width:2px,color:#155724
    classDef cond fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#856404
    classDef action fill:#cce5ff,stroke:#007bff,stroke-width:2px,color:#004085
    classDef ui fill:#e2e3e5,stroke:#6c757d,stroke-width:2px,color:#383d41
    classDef error fill:#f8d7da,stroke:#dc3545,stroke-width:2px,color:#721c24

    Start(["Nhận Props: visible, onClose"]):::init --> UseEffect["Chạy useEffect() để Load Data"]:::action
    UseEffect --> FetchCategories["Lấy Categories đang active (CategoryController)"]:::action
    FetchCategories --> RenderUI["Hiển thị Modal Quản lý Danh mục"]:::ui
    
    subgraph AddCategory [Thêm Danh mục mới]
        RenderUI --> InputNew["Người dùng nhập: Tên, Loại, Màu sắc"]:::ui
        InputNew --> ClickAdd["Nhấn 'Add Category'"]:::action
        ClickAdd --> ValidateName{"Tên có trống không?"}:::cond
        ValidateName -- Có --> AlertError["Hiển thị Alert Lỗi"]:::error
        ValidateName -- Không --> CreateCat["Gọi CategoryController.createCategory()"]:::action
        CreateCat --> ReloadAfterAdd["Clear Input & Gọi lại LoadCategories()"]:::action
    end
    
    subgraph DeleteCategory [Xóa Danh mục hiện tại]
        RenderUI --> ClickDelete["Nhấn icon 'Thùng rác' trên danh mục"]:::action
        ClickDelete --> ConfirmAlert{"Hiển thị Alert Xác nhận"}:::cond
        ConfirmAlert -- Hủy --> CancelDelete["Không làm gì"]:::ui
        ConfirmAlert -- Xóa --> ExecuteDelete["Gọi CategoryController.deleteCategory()"]:::action
        ExecuteDelete --> ReloadAfterDelete["Gọi lại LoadCategories()"]:::action
    end
