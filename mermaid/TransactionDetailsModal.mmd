flowchart TD
    %% Định dạng CSS cho các loại node
    classDef init fill:#d4edda,stroke:#28a745,stroke-width:2px,color:#155724
    classDef cond fill:#fff3cd,stroke:#ffc107,stroke-width:2px,color:#856404
    classDef data fill:#cce5ff,stroke:#007bff,stroke-width:2px,color:#004085
    classDef ui fill:#e2e3e5,stroke:#6c757d,stroke-width:2px,color:#383d41
    classDef action fill:#f8d7da,stroke:#dc3545,stroke-width:2px,color:#721c24

    %% Khởi tạo Component
    Start(["Nhận Props: visible, transaction"]):::init --> CheckCondition{"visible == true & transaction != null?"}:::cond
    
    %% Trường hợp dữ liệu không hợp lệ
    CheckCondition -- False --> ReturnNull(["Return null - Không hiển thị gì"]):::init
    
    %% Trường hợp hiển thị
    CheckCondition -- True --> UseEffect["Chạy useEffect()"]:::data
    UseEffect --> LoadDetails["Gọi hàm async loadDetails()"]:::data
    
    %% Fetching Data
    subgraph DataLoading [Tải dữ liệu quan hệ từ WatermelonDB]
        LoadDetails --> FetchAccount["Truy vấn Account theo transaction.accountId"]:::data
        FetchAccount --> SetAccount["Cập nhật State: setAccount"]:::data
        
        SetAccount --> HasCategory{"transaction.categoryId có tồn tại?"}:::cond
        HasCategory -- Có --> FetchCategory["Truy vấn Category theo transaction.categoryId"]:::data
        FetchCategory --> SetCategory["Cập nhật State: setCategory"]:::data
        
        HasCategory -- Không --> ClearCategory["Cập nhật State: setCategory null"]:::data
    end
    
    %% Render UI preparation
    SetCategory --> PrepareUI["Định dạng tiền tệ & Xác định isIncome"]:::ui
    ClearCategory --> PrepareUI
    
    %% Render UI
    subgraph UIRendering [Hiển thị Giao diện Modal]
        PrepareUI --> RenderModal["Hiển thị Modal với Slide animation"]:::ui
        RenderModal --> RenderBanner["Hiển thị Banner: Màu Đỏ (Expense) / Màu Xanh (Income)"]:::ui
        RenderModal --> RenderDetails["Hiển thị Danh sách chi tiết: Ghi chú, Ngày, Tài khoản, Danh mục"]:::ui
    end
    
    %% Actions
    RenderModal --> UserAction(["Người dùng tương tác"]):::action
    UserAction --> ClickClose["Nhấn nút 'X' hoặc nút 'Đóng'"]:::action
    ClickClose --> CallOnClose["Kích hoạt hàm onClose() gửi về Parent"]:::action
